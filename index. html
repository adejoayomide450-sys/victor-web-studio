<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Victor Web Studio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  background:#050816;
  color:#fff;
  overflow-x:hidden;
}

/* 🌌 BACKGROUND */
.bg-wall{
  position:fixed;
  width:100%;
  height:100%;
  top:0;
  left:0;
  z-index:-3;
  overflow:hidden;
}

.bg-wall img{
  position:absolute;
  width:220px;
  opacity:0.07;
  border-radius:15px;
  animation:floatImg 25s linear infinite;
}

.bg-wall img:nth-child(1){top:10%;left:5%;}
.bg-wall img:nth-child(2){top:25%;left:70%;}
.bg-wall img:nth-child(3){top:60%;left:15%;}
.bg-wall img:nth-child(4){top:80%;left:75%;}

@keyframes floatImg{
  0%{transform:translateY(0) rotate(0deg);}
  50%{transform:translateY(-40px) rotate(5deg);}
  100%{transform:translateY(0) rotate(0deg);}
}

/* 🌈 GRADIENT */
body::before{
  content:"";
  position:fixed;
  width:100%;
  height:100%;
  background:radial-gradient(circle at top,#1e293b,transparent),
             radial-gradient(circle at bottom,#0f172a,transparent);
  z-index:-2;
}

/* NAV */
nav{
  display:flex;
  justify-content:space-between;
  padding:18px 25px;
  position:fixed;
  width:100%;
  top:0;
  background:rgba(0,0,0,0.3);
  backdrop-filter:blur(12px);
  z-index:1000;
}

nav h2{
  color:#facc15;
}

/* HERO */
header{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:120px 20px 60px;
}

.hero h1{
  font-size:3.2rem;
  line-height:1.2;
}

.hero span{
  color:#facc15;
}

.hero p{
  margin-top:15px;
  color:#cbd5e1;
  line-height:1.8;
}

.btn{
  display:inline-block;
  margin-top:25px;
  padding:14px 26px;
  background:#facc15;
  color:#000;
  border-radius:10px;
  font-weight:700;
  text-decoration:none;
  transition:0.3s;
}

.btn:hover{
  transform:scale(1.05);
}

/* SECTION TITLE */
section{
  padding:80px 20px;
}

.title{
  text-align:center;
  font-size:2.2rem;
  margin-bottom:40px;
}

.title span{
  color:#facc15;
}

/* GRID */
.grid{
  max-width:1100px;
  margin:auto;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

/* GLASS CARD */
.card{
  background:rgba(255,255,255,0.05);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,0.08);
  padding:22px;
  border-radius:15px;
  transition:0.3s;
}

.card:hover{
  transform:translateY(-10px);
  border-color:#facc15;
}

.card h3{
  color:#facc15;
  margin-bottom:10px;
}

.card p{
  color:#cbd5e1;
  line-height:1.6;
}

/* FLOAT BUTTON */
.float{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  width:60px;
  height:60px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:24px;
  cursor:pointer;
  box-shadow:0 10px 25px rgba(0,0,0,0.4);
}

/* CHAT BOX */
#chatBox{
  position:fixed;
  bottom:90px;
  right:20px;
  background:#111827;
  padding:15px;
  border-radius:12px;
  width:220px;
  display:none;
}

#chatBox button{
  width:100%;
  margin-top:8px;
  padding:10px;
  border:none;
  border-radius:8px;
  background:#facc15;
  font-weight:600;
}

/* FORM */
#leadForm{
  position:fixed;
  width:100%;
  height:100%;
  top:0;
  left:0;
  background:rgba(0,0,0,0.8);
  display:none;
  align-items:center;
  justify-content:center;
}

.formBox{
  background:#111827;
  padding:20px;
  border-radius:12px;
  width:300px;
}

.formBox input{
  width:100%;
  padding:10px;
  margin-top:10px;
}

/* CHATBOT */
#bot{
  position:fixed;
  bottom:90px;
  left:20px;
  background:#facc15;
  width:55px;
  height:55px;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:22px;
  cursor:pointer;
}

#botBox{
  position:fixed;
  bottom:160px;
  left:20px;
  width:250px;
  background:#111827;
  padding:15px;
  border-radius:12px;
  display:none;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  background:#020617;
  color:#94a3b8;
}
</style>
</head>

<body>

<!-- 🌌 BACKGROUND -->
<div class="bg-wall">
  <img src="https://images.unsplash.com/photo-1522542550221-31fd19575a2d">
  <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c">
  <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085">
  <img src="https://images.unsplash.com/photo-1547658719-da2b51169166">
</div>

<!-- NAV -->
<nav>
  <h2>Victor Studio</h2>
</nav>

<!-- HERO -->
<header>
  <div class="hero">
    <h1>We Build <span>High-End Websites</span></h1>
    <p>We create modern websites that help businesses attract customers and grow online.</p>
    <a class="btn" href="javascript:void(0)" onclick="openChat()">Start Project</a>
  </div>
</header>

<!-- SERVICES -->
<section>
<h2 class="title">Our <span>Services</span></h2>

<div class="grid">
  <div class="card"><h3>Business Websites</h3><p>Professional online presence.</p></div>
  <div class="card"><h3>Landing Pages</h3><p>High conversion pages.</p></div>
  <div class="card"><h3>Portfolio Sites</h3><p>Personal branding websites.</p></div>
</div>
</section>

<!-- WHAT WE BUILD -->
<section>
<h2 class="title">What We Can <span>Build</span></h2>

<div class="grid">

<div class="card">
<h3>E-Commerce Stores</h3>
<p>Online shops with product listings and orders.</p>
</div>

<div class="card">
<h3>School Websites</h3>
<p>Admission, results, and school portals.</p>
</div>

<div class="card">
<h3>Church Platforms</h3>
<p>Livestream, sermons, donations systems.</p>
</div>

<div class="card">
<h3>Sports Systems</h3>
<p>Tournaments, fixtures, and rankings.</p>
</div>

</div>
</section>

<!-- FLOAT -->
<div class="float" onclick="openChat()">💬</div>

<!-- CHAT -->
<div id="chatBox">
  <button onclick="lead('Business Website')">Business Website</button>
  <button onclick="lead('Portfolio')">Portfolio</button>
</div>

<!-- FORM -->
<div id="leadForm">
  <div class="formBox">
    <input id="name" placeholder="Your Name">
    <button onclick="sendWA()">Send</button>
  </div>
</div>

<!-- BOT -->
<div id="bot" onclick="toggleBot()">🤖</div>

<div id="botBox">
  <p><b>Bot:</b> I can help you get a website. Click WhatsApp to continue.</p>
</div>

<!-- FOOTER -->
<footer>© 2026 Victor Web Studio</footer>

<script>

let selected="";

// CHAT
function openChat(){
  let box=document.getElementById("chatBox");
  box.style.display=box.style.display==="block"?"none":"block";
}

function lead(type){
  selected=type;
  document.getElementById("leadForm").style.display="flex";
}

// SEND WHATSAPP
function sendWA(){
  let name=document.getElementById("name").value;

  let msg=`Hi, my name is ${name}. I need a ${selected}.`;

  window.open("https://wa.me/2348133323696?text="+encodeURIComponent(msg));

  document.getElementById("leadForm").style.display="none";
}

// BOT
function toggleBot(){
  let b=document.getElementById("botBox");
  b.style.display=b.style.display==="block"?"none":"block";
}

</script>

</body>
</html>
