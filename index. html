<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Victor Web Studio</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: #050816;
      color: white;
    }

    header {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      background: linear-gradient(135deg, #050816, #0d1230, #111827);
    }

    .hero {
      max-width: 1200px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 40px;
      align-items: center;
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 800;
    }

    h1 span {
      color: #facc15;
    }

    p {
      margin-top: 20px;
      color: #d1d5db;
      line-height: 1.8;
    }

    .btn {
      display: inline-block;
      margin-top: 25px;
      padding: 14px 28px;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
    }

    .btn-primary {
      background: #facc15;
      color: black;
    }

    section {
      padding: 80px 20px;
      text-align: center;
    }

    .services {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      max-width: 1100px;
      margin: auto;
    }

    .card {
      background: #111827;
      padding: 25px;
      border-radius: 15px;
    }

    .card h3 {
      color: #facc15;
      margin-bottom: 10px;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #020617;
      color: #9ca3af;
    }
  </style>
</head>

<body>

<header>
  <div class="hero">
    <div>
      <h1>I Build <span>Modern Websites</span></h1>
      <p>
        I design and develop professional websites for businesses, churches,
        portfolios, and brands that want to grow online.
      </p>

      <a class="btn btn-primary"
         href="https://wa.me/2348133323696?text=Hi%20Victor%2C%20I%20want%20to%20hire%20you"
         target="_blank">
        Hire Me on WhatsApp
      </a>
    </div>
  </div>
</header>

<section>
  <h2>My Services</h2>
  <div class="services">

    <div class="card">
      <h3>Business Websites</h3>
      <p>Professional websites for companies and brands.</p>
    </div>

    <div class="card">
      <h3>Portfolio Websites</h3>
      <p>Showcase your skills and personal brand online.</p>
    </div>

    <div class="card">
      <h3>Church Websites</h3>
      <p>Live streams, sermons, and church information pages.</p>
    </div>

    <div class="card">
      <h3>Event Websites</h3>
      <p>Football tournaments, registrations, and updates.</p>
    </div>

  </div>
</section>

<footer>
  © 2026 Victor Web Studio — All Rights Reserved.
</footer>

</body>
</html>
